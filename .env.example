# Optional Slack reporting for fad-qa.
# Copy this file to ".env" (next to the fad-qa binary) and fill in your
# Slack Incoming Webhook. If ".env" is absent, Slack posting is skipped.
# The real ".env" is gitignored and must NOT be committed.

# Your Slack Incoming Webhook. The full URL or just the path token both work.
# Replace the <...> placeholders with your real webhook path.
SLACK-WEBHOOK-TOKEN=https://hooks.slack.com/services/<workspace-id>/<channel-id>/<secret>

# Informational only (an Incoming Webhook always posts to its fixed channel).
SLACK-CHANNEL=#realift-qa
